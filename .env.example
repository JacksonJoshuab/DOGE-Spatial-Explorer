# ─── DOGE Spatial Editor — Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://doge:doge_secure_password@localhost:5432/doge_spatial

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
APPLE_TEAM_ID=your-apple-team-id
APPLE_CLIENT_ID=your-apple-client-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./keys/apple-auth-key.p8

# ── Cloud Storage (S3 / MinIO) ───────────────────────────────────────────────
S3_BUCKET=doge-spatial-assets
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=doge_admin
S3_SECRET_KEY=doge_secure_password

# ── AI Services ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=https://api.example.com/ai
OPENAI_API_KEY=your-openai-api-key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
MAX_UPLOAD_SIZE=100mb

# ── MinIO Console ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=doge_admin
MINIO_ROOT_PASSWORD=doge_secure_password

# ── Push Notifications ────────────────────────────────────────────────────────
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id
APNS_BUNDLE_ID=com.doge.spatial-editor
FCM_SERVER_KEY=your-fcm-server-key
